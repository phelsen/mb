            <StoryText>
                <DefaultStyle/>
                <ITEXT FONTSIZE="12" CH="- Ik vond geen verslagen"/>
                <para/>
                <ITEXT FONTSIZE="12" CH="- Bloedwaarden redelijk hoog =&gt; naar Mieke gebeld"/>
